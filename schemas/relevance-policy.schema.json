{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-mindsdb-eng.local/schemas/relevance-policy.schema.json",
  "title": "Stage 1 Relevance Policy",
  "type": "object",
  "required": [
    "version",
    "technical_keywords",
    "defer_keywords",
    "watchlist_keywords",
    "ignore_keywords",
    "high_roi_keywords",
    "affected_surface_keywords",
    "risk_flag_keywords",
    "hard_override_keywords"
  ],
  "$defs": {
    "keyword": {
      "type": "string",
      "minLength": 1
    },
    "keywordList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/keyword"
      }
    },
    "keywordMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/keywordList"
      }
    }
  },
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "technical_keywords": {
      "$ref": "#/$defs/keywordList"
    },
    "defer_keywords": {
      "$ref": "#/$defs/keywordList"
    },
    "watchlist_keywords": {
      "$ref": "#/$defs/keywordList"
    },
    "ignore_keywords": {
      "$ref": "#/$defs/keywordList"
    },
    "high_roi_keywords": {
      "$ref": "#/$defs/keywordList"
    },
    "affected_surface_keywords": {
      "$ref": "#/$defs/keywordMap"
    },
    "risk_flag_keywords": {
      "$ref": "#/$defs/keywordMap"
    },
    "hard_override_keywords": {
      "$ref": "#/$defs/keywordMap"
    }
  },
  "additionalProperties": false
}
