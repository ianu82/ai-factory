{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-mindsdb-eng.local/schemas/eval-report.schema.json",
  "title": "Eval Report",
  "type": "object",
  "required": [
    "artifact",
    "spec_packet_id",
    "pr_packet_id",
    "eval_manifest_id",
    "prompt_contract_id",
    "tool_schema_id",
    "golden_dataset_id",
    "latency_baseline_id",
    "build_attempt",
    "evaluated_pr_artifact_version",
    "resulting_pr_artifact_version",
    "tiers",
    "summary"
  ],
  "properties": {
    "artifact": {
      "$ref": "common.schema.json#/$defs/artifactMetadataPolicyBound"
    },
    "spec_packet_id": {
      "type": "string",
      "minLength": 1
    },
    "pr_packet_id": {
      "type": "string",
      "minLength": 1
    },
    "eval_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "prompt_contract_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_schema_id": {
      "type": "string",
      "minLength": 1
    },
    "golden_dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "latency_baseline_id": {
      "type": "string",
      "minLength": 1
    },
    "build_attempt": {
      "type": "integer",
      "minimum": 1
    },
    "evaluated_pr_artifact_version": {
      "type": "integer",
      "minimum": 1
    },
    "resulting_pr_artifact_version": {
      "type": "integer",
      "minimum": 1
    },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "merge_gate",
          "status",
          "checks"
        ],
        "properties": {
          "name": {
            "$ref": "common.schema.json#/$defs/evalTier"
          },
          "merge_gate": {
            "type": "boolean"
          },
          "status": {
            "$ref": "common.schema.json#/$defs/evalTierStatus"
          },
          "checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "id",
                "name",
                "kind",
                "required",
                "status",
                "duration_seconds",
                "summary"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "kind": {
                  "$ref": "common.schema.json#/$defs/evalCheckKind"
                },
                "required": {
                  "type": "boolean"
                },
                "status": {
                  "$ref": "common.schema.json#/$defs/evalCheckStatus"
                },
                "duration_seconds": {
                  "type": "integer",
                  "minimum": 0
                },
                "summary": {
                  "type": "string",
                  "minLength": 1
                },
                "baseline_ref": {
                  "type": "string"
                },
                "threshold_value": {
                  "type": "number"
                },
                "observed_value": {
                  "type": "number"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "merge_gate_tiers",
        "deferred_tiers",
        "merge_gate_passed",
        "recommendation",
        "failing_merge_gate_tiers",
        "failing_check_ids",
        "passed_check_ids",
        "pending_check_ids",
        "warning_count"
      ],
      "properties": {
        "merge_gate_tiers": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/evalTier"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "deferred_tiers": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/evalTier"
          },
          "uniqueItems": true
        },
        "merge_gate_passed": {
          "type": "boolean"
        },
        "recommendation": {
          "type": "string",
          "enum": [
            "advance_to_security_review",
            "return_for_revision"
          ]
        },
        "failing_merge_gate_tiers": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/evalTier"
          },
          "uniqueItems": true
        },
        "failing_check_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "passed_check_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "pending_check_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "summary": {
            "properties": {
              "merge_gate_passed": {
                "const": true
              }
            },
            "required": [
              "merge_gate_passed"
            ]
          }
        },
        "required": [
          "summary"
        ]
      },
      "then": {
        "properties": {
          "summary": {
            "properties": {
              "recommendation": {
                "const": "advance_to_security_review"
              },
              "failing_merge_gate_tiers": {
                "maxItems": 0
              }
            },
            "required": [
              "recommendation",
              "failing_merge_gate_tiers"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "summary": {
            "properties": {
              "merge_gate_passed": {
                "const": false
              }
            },
            "required": [
              "merge_gate_passed"
            ]
          }
        },
        "required": [
          "summary"
        ]
      },
      "then": {
        "properties": {
          "summary": {
            "properties": {
              "recommendation": {
                "const": "return_for_revision"
              },
              "failing_merge_gate_tiers": {
                "minItems": 1
              }
            },
            "required": [
              "recommendation",
              "failing_merge_gate_tiers"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
