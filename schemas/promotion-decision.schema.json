{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-mindsdb-eng.local/schemas/promotion-decision.schema.json",
  "title": "Promotion Decision",
  "type": "object",
  "required": [
    "artifact",
    "spec_packet_id",
    "pr_packet_id",
    "security_review_id",
    "eval_report_id",
    "latency_baseline_id",
    "build_attempt",
    "evaluated_pr_artifact_version",
    "resulting_pr_artifact_version",
    "release_runbook",
    "rollback_plan",
    "staging_report",
    "promotion_decision",
    "summary"
  ],
  "properties": {
    "artifact": {
      "$ref": "common.schema.json#/$defs/artifactMetadataPolicyBound"
    },
    "spec_packet_id": {
      "type": "string",
      "minLength": 1
    },
    "pr_packet_id": {
      "type": "string",
      "minLength": 1
    },
    "security_review_id": {
      "type": "string",
      "minLength": 1
    },
    "eval_report_id": {
      "type": "string",
      "minLength": 1
    },
    "latency_baseline_id": {
      "type": "string",
      "minLength": 1
    },
    "build_attempt": {
      "type": "integer",
      "minimum": 1
    },
    "evaluated_pr_artifact_version": {
      "type": "integer",
      "minimum": 1
    },
    "resulting_pr_artifact_version": {
      "type": "integer",
      "minimum": 1
    },
    "release_runbook": {
      "type": "object",
      "required": [
        "feature_flag",
        "strategy",
        "traffic_mode",
        "staged_steps",
        "auto_promote_allowed"
      ],
      "properties": {
        "feature_flag": {
          "type": "string",
          "minLength": 1
        },
        "strategy": {
          "type": "string",
          "enum": [
            "short_soak_or_shadow",
            "canary_then_soak",
            "staged_rollout_with_signoff"
          ]
        },
        "traffic_mode": {
          "type": "string",
          "enum": [
            "shadow",
            "canary",
            "staged_rollout"
          ]
        },
        "staged_steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "auto_promote_allowed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "rollback_plan": {
      "type": "object",
      "required": [
        "tested",
        "blast_radius",
        "rollback_class",
        "trigger_conditions",
        "steps"
      ],
      "properties": {
        "tested": {
          "type": "boolean"
        },
        "blast_radius": {
          "type": "string",
          "minLength": 1
        },
        "rollback_class": {
          "$ref": "common.schema.json#/$defs/rollbackClass"
        },
        "trigger_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "staging_report": {
      "type": "object",
      "required": [
        "environment",
        "traffic_mode",
        "soak_minutes_observed",
        "minimum_soak_minutes",
        "request_samples_observed",
        "minimum_request_samples",
        "feature_flag_enabled",
        "rollback_tested",
        "metrics",
        "threshold_breaches"
      ],
      "properties": {
        "environment": {
          "type": "string",
          "enum": [
            "staging",
            "shadow",
            "canary"
          ]
        },
        "traffic_mode": {
          "type": "string",
          "enum": [
            "shadow",
            "canary",
            "staged_rollout"
          ]
        },
        "soak_minutes_observed": {
          "type": "integer",
          "minimum": 0
        },
        "minimum_soak_minutes": {
          "type": "integer",
          "minimum": 0
        },
        "request_samples_observed": {
          "type": "integer",
          "minimum": 0
        },
        "minimum_request_samples": {
          "type": "integer",
          "minimum": 0
        },
        "feature_flag_enabled": {
          "type": "boolean"
        },
        "rollback_tested": {
          "type": "boolean"
        },
        "metrics": {
          "type": "object",
          "required": [
            "error_rate_pct",
            "p95_latency_ms",
            "cost_per_call_usd",
            "quality_score",
            "fallback_rate_pct",
            "business_kpi_proxy"
          ],
          "properties": {
            "error_rate_pct": {
              "type": "number",
              "minimum": 0
            },
            "p95_latency_ms": {
              "type": "integer",
              "minimum": 0
            },
            "cost_per_call_usd": {
              "type": "number",
              "minimum": 0
            },
            "quality_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "fallback_rate_pct": {
              "type": "number",
              "minimum": 0
            },
            "business_kpi_proxy": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": false
        },
        "threshold_breaches": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "promotion_decision": {
      "type": "object",
      "required": [
        "status",
        "mode",
        "approvals_granted",
        "pending_approvals",
        "rationale"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "promoted",
            "pending_human",
            "blocked"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "auto",
            "human_required",
            "human_approved"
          ]
        },
        "approvals_granted": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/approvalRequirement"
          },
          "uniqueItems": true
        },
        "pending_approvals": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/approvalRequirement"
          },
          "uniqueItems": true
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "threshold_breaches",
        "watch_items",
        "passed_checks"
      ],
      "properties": {
        "threshold_breaches": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "watch_items": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "passed_checks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "promotion_decision": {
            "properties": {
              "status": {
                "const": "promoted"
              }
            },
            "required": [
              "status"
            ]
          }
        },
        "required": [
          "promotion_decision"
        ]
      },
      "then": {
        "properties": {
          "summary": {
            "properties": {
              "threshold_breaches": {
                "maxItems": 0
              }
            },
            "required": [
              "threshold_breaches"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "promotion_decision": {
            "properties": {
              "status": {
                "const": "pending_human"
              }
            },
            "required": [
              "status"
            ]
          }
        },
        "required": [
          "promotion_decision"
        ]
      },
      "then": {
        "properties": {
          "promotion_decision": {
            "properties": {
              "mode": {
                "const": "human_required"
              }
            },
            "required": [
              "mode"
            ]
          },
          "summary": {
            "properties": {
              "threshold_breaches": {
                "maxItems": 0
              }
            },
            "required": [
              "threshold_breaches"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "promotion_decision": {
            "properties": {
              "status": {
                "const": "blocked"
              }
            },
            "required": [
              "status"
            ]
          }
        },
        "required": [
          "promotion_decision"
        ]
      },
      "then": {
        "properties": {
          "summary": {
            "properties": {
              "threshold_breaches": {
                "minItems": 1
              }
            },
            "required": [
              "threshold_breaches"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
