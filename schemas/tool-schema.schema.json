{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-mindsdb-eng.local/schemas/tool-schema.schema.json",
  "title": "Tool Schema Artifact",
  "type": "object",
  "required": [
    "artifact",
    "spec_packet_id",
    "prompt_contract_id",
    "tools"
  ],
  "properties": {
    "artifact": {
      "$ref": "common.schema.json#/$defs/artifactMetadataPolicyBound"
    },
    "spec_packet_id": {
      "type": "string",
      "minLength": 1
    },
    "prompt_contract_id": {
      "type": "string",
      "minLength": 1
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "input_schema",
          "output_schema",
          "permissions",
          "failure_modes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "input_schema": {
            "type": "object"
          },
          "output_schema": {
            "type": "object"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "failure_modes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "condition",
                "behavior",
                "retryable"
              ],
              "properties": {
                "condition": {
                  "type": "string",
                  "minLength": 1
                },
                "behavior": {
                  "type": "string",
                  "minLength": 1
                },
                "retryable": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
