# Private local settings for Codex and the factory CLI.
# The CLI auto-loads `.env` and then `.env.local` from the repo root.

OPENAI_API_KEY=
AI_FACTORY_AGENT_PROVIDER=openai
AI_FACTORY_OPENAI_MODEL=gpt-5.4
AI_FACTORY_OPENAI_FALLBACK_MODEL=gpt-5.4-mini
AI_FACTORY_OPENAI_REASONING_EFFORT=medium
AI_FACTORY_OPENAI_MAX_OUTPUT_TOKENS=4000
AI_FACTORY_OPENAI_TIMEOUT_SECONDS=120

LINEAR_WEBHOOK_SECRET=
LINEAR_API_KEY=
LINEAR_TARGET_TEAM_ID=
LINEAR_TARGET_STATE_ID=
LINEAR_COMMENT_ON_ACCEPT=true
LINEAR_COMMENT_ON_REJECT=true
LINEAR_FACTORY_CREATE_STATES=true
LINEAR_FACTORY_SYNC_DISABLED=false
FACTORY_TRIGGER_BASE_URL=
